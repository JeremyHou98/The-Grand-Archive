# Copy to .env and replace with your private RSSHub endpoint
RSSHUB_BASE_URL=https://your-private-rsshub.example.com

# Server
DB_PATH=/data/dak.db
PORT=3000
JWT_SECRET=change-me-to-random-32-bytes
COOKIE_DOMAIN=localhost

# Litestream → Cloudflare R2
R2_REPLICA_URL=s3://dak-backup/dak.db
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Ingestion Worker
DAK_SERVER_URL=http://localhost:3000
DAK_API_KEY=

# RSSHub
RSSHUB_BASE_URL=http://localhost:1200

RESEND_API_KEY=

# Social Auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
