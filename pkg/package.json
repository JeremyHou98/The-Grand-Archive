{
  "name": "@littlelittlecloud/dak",
  "version": "0.1.0",
  "description": "大案牍库 — RSS Feed 数据包，提供 feeds 访问与全文搜索能力",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LittleLittleCloud/The-Grand-Archive.git",
    "directory": "pkg"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./feeds": {
      "types": "./dist/feeds.d.ts",
      "import": "./dist/feeds.js",
      "require": "./dist/feeds.cjs"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js",
      "require": "./dist/search.cjs"
    }
  },
  "bin": {
    "dak": "dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "build:data": "bun run scripts/build-data.ts",
    "build:ts": "tsup",
    "build": "bun run build:data && bun run build:ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "rss",
    "feeds",
    "search",
    "大案牍库",
    "news"
  ],
  "license": "MIT",
  "dependencies": {
    "minisearch": "^7.1.1"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
